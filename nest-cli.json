{
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"projects": {},
	"compilerOptions": {
		"webpack": true,
		"deleteOutDir": true,
		"tsConfigPath": "src/tsconfig.json",
		"assets": [],
		"watchAssets": true,
		"plugins": [
			{
				"name": "@nestjs/swagger",
				"options": {
					"introspectComments": true
				}
			}
		]
	}
}